# Copy to .env.local for local development.

# GCP/Firebase project (required for Firestore)
GOOGLE_CLOUD_PROJECT=your-firebase-project-id

# Optional: Firebase service account JSON (if not using gcloud default credentials)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: Nokia Network as Code (without these, mock responses are used)
# NAC_API_KEY=your-nac-api-key
# NAC_BASE_URL=https://network-as-code.nokia.io
