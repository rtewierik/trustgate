# Copy to .env.local for local development.
# For Firebase App Hosting, set these in apphosting.yaml (and Firebase Console for secrets).
# See DEBUGGING-CLOUDBUILD.md and README for deploy env setup.

# ---- Required ----
# Google Cloud / Firebase project ID (BUILD + RUNTIME in App Hosting)
GOOGLE_CLOUD_PROJECT=openg-hack26bar-512

# ---- Optional: same-origin API ----
# Leave empty when front and API are same origin. Set if API is on another domain.
# Next.js inlines this at build time (NEXT_PUBLIC_*), so it must be in apphosting.yaml with BUILD.
NEXT_PUBLIC_API_URL=

# ---- Optional: canonical app URL ----
# Used for redirect/callback URLs. If unset, app uses request origin. RUNTIME only in App Hosting.
NEXT_PUBLIC_APP_URL=

# ---- Optional: Firebase service account (local only) ----
# JSON string of service account key. If unset and GOOGLE_CLOUD_PROJECT is set, App Hosting uses default credentials.
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- Optional: Nokia Network as Code ----
# API key for Number Verification / SIM Swap / KYC. Without it, those features use mocks or fail at runtime.
# In App Hosting: use Secret Manager and apphosting.yaml (secret: nac-api-key).
NAC_API_KEY=
