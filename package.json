{
  "name": "trustgate",
  "version": "0.1.0",
  "private": true,
  "description": "TrustGate — Verificación de Identidad Instantánea por Red Telecom",
  "scripts": {
    "dev": "next dev",
    "dev:emulator": "FIRESTORE_EMULATOR_HOST=localhost:8080 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "emulators": "firebase emulators:start --only firestore",
    "deploy": "npm run lint && firebase deploy",
    "destroy": "firebase apphosting:backends:delete trustgate --force && firebase firestore:delete verifications --recursive",
    "destroy:apphosting": "firebase apphosting:backends:delete trustgate --force",
    "destroy:firestore": "firebase firestore:delete verifications --recursive -y"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "network-as-code": "^6.0.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
